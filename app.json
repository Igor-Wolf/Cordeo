{
  "expo": {
    "name": "cordeo",
    "slug": "cordeo",
    "version": "0.8.1",
    "orientation": "portrait",
    "icon": "./assets/logoicon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logoicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoicon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.afinador"
    },
    "web": {
      "favicon": "./assets/logoicon.png"
    }
  }
}
